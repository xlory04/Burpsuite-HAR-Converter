# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
pip-wheel-metadata/
MANIFEST
.eggs/
wheels/

# ── Build and distribution ─────────────────────────────────────────────────────
dist/
build/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Secrets and credentials ────────────────────────────────────────────────────
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
secrets/
credentials/
keys/
private/
.secrets
.env
.env.*
!.env.example

# ── Security / pentest artifacts ───────────────────────────────────────────────
# XML and HAR files are test data — never commit actual captures to the repo.
*.xml
*.har
captures/
exports/
traffic/
burp_exports/
sessions/

# ── Test fixtures (tracked exceptions go in tests/fixtures/ explicitly) ────────
tests/*.xml
tests/*.har

# ── Reports and analysis ───────────────────────────────────────────────────────
report.md
reports/
*.report
*.log
logs/

# ── Local tool state ───────────────────────────────────────────────────────────
# ~/.burp2har/ lives in the home directory, not the project tree,
# but add it here in case someone runs the tool from the repo root.
.burp2har/

# ── Claude Code ────────────────────────────────────────────────────────────────
.claude/

# ── IDE and editor files ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS-generated files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Testing and coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
